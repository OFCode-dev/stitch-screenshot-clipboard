{
  "manifest_version": 3,
  "name": "Stitch Screenshot → Clipboard",
  "short_name": "Stitch Screenshot",
  "version": "1.0.0",
  "description": "One click: scrolls the page, stitches a full-page screenshot and copies it straight to your clipboard.",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "action": {
    "default_title": "Stitch screenshot → clipboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Capture stitched screenshot to clipboard"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
